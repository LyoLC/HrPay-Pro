rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /funcionarios/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /contratos/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /assiduidade/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /atividades/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /processamento_salarial/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /configuracoes/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Deny access to anything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
