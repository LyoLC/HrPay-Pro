rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /contracts/{contractId} {
      allow read, write: if request.auth != null;
    }
    match /employee_docs/{docId} {
      allow read, write: if request.auth != null;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
